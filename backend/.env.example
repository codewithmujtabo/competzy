# ─────────────────────────────────────────────────────────────────────────
# Competzy backend — environment variables (Coolify deployment)
# Copy to .env locally, or paste each line into the Coolify
# "Environment Variables" tab on the backend service.
# ─────────────────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=3000

# ── Database ─────────────────────────────────────────────────────────────
# Coolify PostgreSQL: copy the internal "Connection String" from the DB
# service page. Use the *internal* hostname (service name), not the public
# one — the backend container reaches Postgres over Coolify's docker network.
DATABASE_URL=postgresql://postgres:CHANGE_ME@postgres-service:5432/competzy

# ── Auth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-random-string-at-least-32-characters
JWT_EXPIRES_IN=7d

# ── CORS / app URL ───────────────────────────────────────────────────────
# Comma-separated origins the API will accept cookie-bearing requests from.
# arena.competzy.com is the portal; add staging hosts here.
CORS_ORIGINS=https://arena.competzy.com
# Used for outbound email links (password reset, invitations).
APP_URL=https://arena.competzy.com

# ── Email (SMTP) ─────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Competzy <noreply@competzy.id>
OTP_EXPIRY_MINUTES=10

# ── Sentry — DSN from https://sentry.io → Project → Settings → Client Keys
SENTRY_DSN=

# ── Twilio Verify — from console.twilio.com (TWILIO_VERIFY_SID looks like VA...)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_VERIFY_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Midtrans — https://dashboard.sandbox.midtrans.com → Settings → Access Keys
# Use sandbox keys for dev; switch to production keys for live.
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxx
MIDTRANS_IS_PRODUCTION=false

# ── API.co.id — Indonesian school database API (https://api.co.id)
API_CO_ID_KEY=your-api-co-id-key-here

# ── Object storage (MinIO running on Coolify) ────────────────────────────
# Add MinIO as a separate Coolify service. Use the internal docker hostname
# here — container-to-container traffic stays inside the docker network.
# MINIO_PUBLIC_URL is what browsers see: the public HTTPS URL Coolify
# assigns to the MinIO service, e.g. https://minio.arena.competzy.com.
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=competzy
MINIO_PUBLIC_URL=https://minio.arena.competzy.com

