# ─────────────────────────────────────────────────────────────────────────
# Competzy backend — environment variables (Coolify deployment)
# Copy to .env locally, or paste each line into the Coolify
# "Environment Variables" tab on the backend service.
# ─────────────────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=3000

# ── Database ─────────────────────────────────────────────────────────────
# Coolify PostgreSQL: copy the internal "Connection String" from the DB
# service page. Use the *internal* hostname (service name), not the public
# one — the backend container reaches Postgres over Coolify's docker network.
DATABASE_URL=postgresql://postgres:CHANGE_ME@postgres-service:5432/competzy

# ── Auth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-random-string-at-least-32-characters
JWT_EXPIRES_IN=7d

# ── CORS / app URL ───────────────────────────────────────────────────────
# Comma-separated origins the API will accept cookie-bearing requests from.
# arena.competzy.com is the portal; add staging hosts here.
CORS_ORIGINS=https://arena.competzy.com
# Used for outbound email links (password reset, invitations).
APP_URL=https://arena.competzy.com

# ── Email (SMTP) ─────────────────────────────────────────────────────────
# REQUIRED in production: email verification, password reset, and login OTP
# all silently stop delivering without working SMTP_USER + SMTP_PASS.
#
# Production uses Resend (https://resend.com) with the verified domain
# competzy.com. SMTP_USER is the literal string "resend"; SMTP_PASS is a
# Resend API key (re_...) with Sending access — create one per environment
# (Resend dashboard → API Keys) so local/staging/prod can be revoked
# independently. SMTP_FROM's address MUST be on the verified domain.
# Any SMTP provider works (it's plain nodemailer) — swap the 5 vars below.
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_your-resend-api-key
SMTP_FROM=Competzy <noreply@competzy.com>
OTP_EXPIRY_MINUTES=10

# ── Sentry — DSN from https://sentry.io → Project → Settings → Client Keys
SENTRY_DSN=

# ── Twilio Verify — from console.twilio.com (TWILIO_VERIFY_SID looks like VA...)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_VERIFY_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Midtrans — Settings → Access Keys
#   Sandbox keys (dev):  https://dashboard.sandbox.midtrans.com  (SB-Mid-... + IS_PRODUCTION=false)
#   Production keys:     https://dashboard.midtrans.com          (Mid-...    + IS_PRODUCTION=true)
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxx
MIDTRANS_IS_PRODUCTION=false
# Only set this when sharing a Midtrans account with another site (e.g. the
# legacy EMC/kompetisi.net account, whose dashboard notification URL points at
# emc.kompetisi.net). It overrides the notification URL to Competzy's webhook
# for OUR transactions only. MUST be Competzy's own webhook — NOT the legacy one.
# Leave blank on a dedicated Competzy account (then set the dashboard URL instead).
# MIDTRANS_NOTIFICATION_URL=https://api.competzy.com/api/payments/webhook

# ── API.co.id — Indonesian school database API (https://api.co.id)
API_CO_ID_KEY=your-api-co-id-key-here

# ── Waitlist receiver (POST /api/waitlist)
# Shared secret the competzy-web subdomains include as `Authorization:
# Bearer <token>` when forwarding signups. Must match the value set in
# competzy-web's `ARENA_WAITLIST_TOKEN`. Generate with:
#   openssl rand -hex 32
# Leave empty to accept unauthenticated requests (dev/initial-rollout only).
ARENA_WAITLIST_TOKEN=

# ── Maintenance toggle — admin bypass cookie
# HMAC secret for the `competzy_bypass` cookie that lets admins skip the
# maintenance takeover page on every .competzy.com subdomain. MUST match
# competzy-web's `BYPASS_COOKIE_SECRET`. Generate with:
#   openssl rand -hex 32
# Leave empty to disable the bypass entirely (admins will see the
# maintenance page like the public).
BYPASS_COOKIE_SECRET=
# Cookie domain for the bypass cookie. In production use `.competzy.com`
# (leading dot — required so the cookie is visible to every subdomain).
# Leave empty in dev — the cookie will scope to the request host.
BYPASS_COOKIE_DOMAIN=.competzy.com

# ── Object storage (MinIO running on Coolify) ────────────────────────────
# Add MinIO as a separate Coolify service. Use the internal docker hostname
# here — container-to-container traffic stays inside the docker network.
# MINIO_PUBLIC_URL is what browsers see: the public HTTPS URL Coolify
# assigns to the MinIO service, e.g. https://minio.arena.competzy.com.
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=competzy
MINIO_PUBLIC_URL=https://minio.arena.competzy.com
