# Hoist all @types/* packages to the top-level node_modules so TypeScript
# can resolve transitive type references through the strict pnpm symlink
# layout. Without this, TS2742 fires on every Router/app inferred type
# because `@types/express-serve-static-core` lives under
# `.pnpm/@types+...@x.y.z/node_modules/` which TS can't follow without
# explicit annotations on every router definition.
public-hoist-pattern[]=@types/*
