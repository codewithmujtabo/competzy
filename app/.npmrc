# Expo / React Native compat — Metro's resolver historically chokes on
# pnpm's strict symlinked node_modules layout. Hoist all deps to a flat
# top-level node_modules to match npm/yarn behavior. Without this,
# `expo start` may fail with "Unable to resolve module …" for transitive
# peer deps that Metro can't follow through the symlink graph.
node-linker=hoisted
